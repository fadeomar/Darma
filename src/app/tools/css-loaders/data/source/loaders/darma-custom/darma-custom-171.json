  "html": "<div class=\"loader\"></div>",
  "css": ".loader {\n  color: #0891b2;\nwidth: 60px;\naspect-ratio: 4;\nbackground: radial-gradient(circle closest-side,currentColor 90%,#0000) 0/calc(100%/3) 100% space;\nclip-path: inset(0 100% 0 0);\nanimation: l1 1s steps(4) infinite;\n}\n@keyframes l1 {to{clip-path: inset(0 -34% 0 0)}}\n",
  "source": {
    "name": "Darma custom loaders",
    "author": "Darma",
    "license": "Custom"
  },
  "controls": {
    "color": true,
    "secondaryColor": false,
    "size": true,
    "speed": true,
    "background": false
  },
  "defaults": {
    "color": "#0891b2",
    "secondaryColor": "#22d3ee",
    "size": 60,
    "speed": 1.0,
    "background": "#ffffff"
  },
  "flags": {
    "popular": false,
