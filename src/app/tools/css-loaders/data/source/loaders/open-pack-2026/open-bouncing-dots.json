{
  "id": "open-bouncing-dots",
  "name": "Open Bouncing Dots",
  "category": "dots",
  "tags": [
    "open-source",
    "open-pack-2026",
    "dots",
    "bounce",
    "minimal"
  ],
  "html": "<span class=\"darma-loader-open-bouncing-dots\"><i></i><i></i><i></i></span>",
  "css": ".darma-loader-open-bouncing-dots{display:inline-flex;align-items:flex-end;gap:8px;height:42px}.darma-loader-open-bouncing-dots i{width:12px;height:12px;border-radius:50%;background:var(--loader-color,#0891b2);animation:darma-loader-open-bouncing-dots-hop var(--loader-speed,.78s) cubic-bezier(.38,0,.2,1) infinite}.darma-loader-open-bouncing-dots i:nth-child(2){animation-delay:.12s;background:var(--loader-secondary-color,#06b6d4)}.darma-loader-open-bouncing-dots i:nth-child(3){animation-delay:.24s}@keyframes darma-loader-open-bouncing-dots-hop{0%,100%{transform:translateY(0) scale(1);opacity:.55}45%{transform:translateY(-24px) scale(1.08);opacity:1}}",
  "source": {
    "name": "Loaders.css inspired pattern",
    "author": "Connor Atherton / open-source CSS loader community",
    "license": "MIT-inspired pattern, normalized by Darma",
    "url": "https://github.com/ConnorAtherton/loaders.css"
  },
  "controls": {
    "color": true,
    "secondaryColor": true,
    "size": true,
    "speed": true,
    "background": false
  },
  "defaults": {
    "color": "#0891b2",
    "secondaryColor": "#06b6d4",
    "size": 54,
    "speed": 0.78,
    "background": "#ffffff"
  },
  "flags": {
    "cssOnly": true,
    "customizable": true,
    "singleElement": false
  }
}
