  "html": "<section class=\"container\">\n  <section class=\"loader\">\n    <article style=\"--rot: 0\" class=\"sphere sphere1\">\n      <div class=\"item\" style=\"--rot-y: 1\"></div>\n      <div class=\"item\" style=\"--rot-y: 2\"></div>\n      <div class=\"item\" style=\"--rot-y: 3\"></div>\n      <div class=\"item\" style=\"--rot-y: 4\"></div>\n      <div class=\"item\" style=\"--rot-y: 5\"></div>\n      <div class=\"item\" style=\"--rot-y: 6\"></div>\n      <div class=\"item\" style=\"--rot-y: 7\"></div>\n      <div class=\"item\" style=\"--rot-y: 8\"></div>\n      <div class=\"item\" style=\"--rot-y: 9\"></div>\n    </article>\n    <article style=\"--rot: 1\" class=\"sphere sphere2\">\n      <div class=\"item\" style=\"--rot-y: 1\"></div>\n      <div class=\"item\" style=\"--rot-y: 2\"></div>\n      <div class=\"item\" style=\"--rot-y: 3\"></div>\n      <div class=\"item\" style=\"--rot-y: 4\"></div>\n      <div class=\"item\" style=\"--rot-y: 5\"></div>\n      <div class=\"item\" style=\"--rot-y: 6\"></div>\n      <div class=\"item\" style=\"--rot-y: 7\"></div>\n      <div class=\"item\" style=\"--rot-y: 8\"></div>\n      <div class=\"item\" style=\"--rot-y: 9\"></div>\n    </article>\n    <article style=\"--rot: 2\" class=\"sphere sphere3\">\n      <div class=\"item\" style=\"--rot-y: 1\"></div>\n      <div class=\"item\" style=\"--rot-y: 2\"></div>\n      <div class=\"item\" style=\"--rot-y: 3\"></div>\n      <div class=\"item\" style=\"--rot-y: 4\"></div>\n      <div class=\"item\" style=\"--rot-y: 5\"></div>\n      <div class=\"item\" style=\"--rot-y: 6\"></div>\n      <div class=\"item\" style=\"--rot-y: 7\"></div>\n      <div class=\"item\" style=\"--rot-y: 8\"></div>\n      <div class=\"item\" style=\"--rot-y: 9\"></div>\n    </article>\n    <article style=\"--rot: 3\" class=\"sphere sphere4\">\n      <div class=\"item\" style=\"--rot-y: 1\"></div>\n      <div class=\"item\" style=\"--rot-y: 2\"></div>\n      <div class=\"item\" style=\"--rot-y: 3\"></div>\n      <div class=\"item\" style=\"--rot-y: 4\"></div>\n      <div class=\"item\" style=\"--rot-y: 5\"></div>\n      <div class=\"item\" style=\"--rot-y: 6\"></div>\n      <div class=\"item\" style=\"--rot-y: 7\"></div>\n      <div class=\"item\" style=\"--rot-y: 8\"></div>\n      <div class=\"item\" style=\"--rot-y: 9\"></div>\n    </article>\n    <article style=\"--rot: 4\" class=\"sphere sphere5\">\n      <div class=\"item\" style=\"--rot-y: 1\"></div>\n      <div class=\"item\" style=\"--rot-y: 2\"></div>\n      <div class=\"item\" style=\"--rot-y: 3\"></div>\n      <div class=\"item\" style=\"--rot-y: 4\"></div>\n      <div class=\"item\" style=\"--rot-y: 5\"></div>\n      <div class=\"item\" style=\"--rot-y: 6\"></div>\n      <div class=\"item\" style=\"--rot-y: 7\"></div>\n      <div class=\"item\" style=\"--rot-y: 8\"></div>\n      <div class=\"item\" style=\"--rot-y: 9\"></div>\n    </article>\n    <article style=\"--rot: 5\" class=\"sphere sphere6\">\n      <div class=\"item\" style=\"--rot-y: 1\"></div>\n      <div class=\"item\" style=\"--rot-y: 2\"></div>\n      <div class=\"item\" style=\"--rot-y: 3\"></div>\n      <div class=\"item\" style=\"--rot-y: 4\"></div>\n      <div class=\"item\" style=\"--rot-y: 5\"></div>\n      <div class=\"item\" style=\"--rot-y: 6\"></div>\n      <div class=\"item\" style=\"--rot-y: 7\"></div>\n      <div class=\"item\" style=\"--rot-y: 8\"></div>\n      <div class=\"item\" style=\"--rot-y: 9\"></div>\n    </article>\n    <article style=\"--rot: 6\" class=\"sphere sphere7\">\n      <div class=\"item\" style=\"--rot-y: 1\"></div>\n      <div class=\"item\" style=\"--rot-y: 2\"></div>\n      <div class=\"item\" style=\"--rot-y: 3\"></div>\n      <div class=\"item\" style=\"--rot-y: 4\"></div>\n      <div class=\"item\" style=\"--rot-y: 5\"></div>\n      <div class=\"item\" style=\"--rot-y: 6\"></div>\n      <div class=\"item\" style=\"--rot-y: 7\"></div>\n      <div class=\"item\" style=\"--rot-y: 8\"></div>\n      <div class=\"item\" style=\"--rot-y: 9\"></div>\n    </article>\n    <article style=\"--rot: 7\" class=\"sphere sphere8\">\n      <div class=\"item\" style=\"--rot-y: 1\"></div>\n      <div class=\"item\" style=\"--rot-y: 2\"></div>\n      <div class=\"item\" style=\"--rot-y: 3\"></div>\n      <div class=\"item\" style=\"--rot-y: 4\"></div>\n      <div class=\"item\" style=\"--rot-y: 5\"></div>\n      <div class=\"item\" style=\"--rot-y: 6\"></div>\n      <div class=\"item\" style=\"--rot-y: 7\"></div>\n      <div class=\"item\" style=\"--rot-y: 8\"></div>\n      <div class=\"item\" style=\"--rot-y: 9\"></div>\n    </article>\n    <article style=\"--rot: 8\" class=\"sphere sphere9\">\n      <div class=\"item\" style=\"--rot-y: 1\"></div>\n      <div class=\"item\" style=\"--rot-y: 2\"></div>\n      <div class=\"item\" style=\"--rot-y: 3\"></div>\n      <div class=\"item\" style=\"--rot-y: 4\"></div>\n      <div class=\"item\" style=\"--rot-y: 5\"></div>\n      <div class=\"item\" style=\"--rot-y: 6\"></div>\n      <div class=\"item\" style=\"--rot-y: 7\"></div>\n      <div class=\"item\" style=\"--rot-y: 8\"></div>\n      <div class=\"item\" style=\"--rot-y: 9\"></div>\n    </article>\n  </section>\n</section>",
  "css": ".container {color: var(--loader-color, #a855f7);\n  --loader-secondary-color: #22d3ee;\n  --loader-bg: #0f172a;\n  \n  position: relative;\n  width: 118px;\n  height: 118px;\n  display: grid;\n  place-items: center;\n  overflow: visible;\n}\n.container .loader {\n  width: 118px;\n  height: 118px;\n  position: relative;\n  transform-style: preserve-3d;\n  perspective: 10000px;\n  animation: girar var(--loader-speed, 8s) linear infinite;\n}\n.container .sphere,\n.container .item {\n  width: 118px;\n  height: 118px;\n  position: absolute;\n  inset: 0;\n  transform-style: preserve-3d;\n  perspective: 10000px;\n}\n.container .sphere { transform: rotate(calc(var(--rot) * 20deg)); }\n.container .sphere1 { --bg: color-mix(in srgb, #ef4444 55%, transparent); }\n.container .sphere2 { --bg: color-mix(in srgb, #f472b6 55%, transparent); }\n.container .sphere3 { --bg: color-mix(in srgb, #fde047 55%, transparent); }\n.container .sphere4 { --bg: color-mix(in srgb, #22c55e 55%, transparent); }\n.container .sphere5 { --bg: color-mix(in srgb, var(--loader-secondary-color, #22d3ee) 55%, transparent); }\n.container .sphere6 { --bg: color-mix(in srgb, var(--loader-color, #2563eb) 55%, transparent); }\n.container .sphere7 { --bg: color-mix(in srgb, #d946ef 55%, transparent); }\n.container .sphere8 { --bg: color-mix(in srgb, #fb923c 55%, transparent); }\n.container .sphere9 { --bg: color-mix(in srgb, #e5b2ca 55%, transparent); }\n.container .item {\n  border-radius: 50%;\n  background: var(--bg);\n  transform: rotateY(calc(var(--rot-y) * 40deg));\n}\n@keyframes girar {\n  0% { transform: rotateX(0deg) rotateY(0deg); }\n  100% { transform: rotateX(360deg) rotateY(360deg); }\n}\n",
  "source": {
    "name": "Darma rich loaders",
