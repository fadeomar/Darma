{
  "id": "uiverse-propeller-tick-spinner",
  "name": "Propeller Tick Spinner",
  "category": "spinners",
  "tags": [
    "ticks",
    "propeller",
    "radial",
    "spinner",
    "uiverse",
    "batch-5"
  ],
  "html": "<div class=\"loader spinner\">\n  <div style=\"--delay:.1;--rotation:36;--translation:150;\"></div><div style=\"--delay:.2;--rotation:72;--translation:150;\"></div><div style=\"--delay:.3;--rotation:108;--translation:150;\"></div><div style=\"--delay:.4;--rotation:144;--translation:150;\"></div><div style=\"--delay:.5;--rotation:180;--translation:150;\"></div><div style=\"--delay:.6;--rotation:216;--translation:150;\"></div><div style=\"--delay:.7;--rotation:252;--translation:150;\"></div><div style=\"--delay:.8;--rotation:288;--translation:150;\"></div><div style=\"--delay:.9;--rotation:324;--translation:150;\"></div><div style=\"--delay:1;--rotation:360;--translation:150;\"></div>\n</div>\n",
  "css": ".spinner { position: relative; width: 34px; height: 34px; }\n.spinner div {\n  position: absolute;\n  left: 50%;\n  top: 50%;\n  width: 4px;\n  height: 18px;\n  border-radius: 4px;\n  background: #000000;\n  transform: rotate(calc(var(--rotation) * 1deg)) translate(0, calc(var(--translation) * 1%));\n  animation: propellerTick 1s calc(var(--delay) * 1s) infinite ease;\n  transform-origin: 50% 0;\n}\n@keyframes propellerTick { 0%, 100% { opacity: .15; } 50% { opacity: 1; } }\n",
  "source": {
    "name": "Uiverse snippet collection",
    "author": "community",
    "license": "Unknown"
  },
  "controls": {
    "color": true,
    "size": true,
    "speed": true,
    "background": false,
    "secondaryColor": true
  },
  "defaults": {
    "size": 34,
    "speed": 1,
    "color": "#000000",
    "secondaryColor": "#777777"
  },
  "flags": {
    "popular": false,
    "singleElement": false,
    "cssOnly": true,
    "tailwind": false,
    "customizable": true
  }
}
