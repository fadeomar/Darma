ntainer .darma-loader-darma-custom-656__sphere8 { --bg: color-mix(in srgb, #fb923c 55%, transparent); }\n.darma-loader-darma-custom-656__container .darma-loader-darma-custom-656__sphere9 { --bg: color-mix(in srgb, #e5b2ca 55%, transparent); }\n.darma-loader-darma-custom-656__container .darma-loader-darma-custom-656__item {\n  border-radius: 50%;\n  background: var(--bg);\n  transform: rotateY(calc(var(--rot-y) * 40deg));\n}\n@keyframes darma-loader-darma-custom-656-girar {\n  0% { transform: rotateX(0deg) rotateY(0deg); }\n  100% { transform: rotateX(360deg) rotateY(360deg); }\n}\n",
