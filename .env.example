# ─────────────────────────────────────────────────────────────
# Darma environment variables
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
# `.env` is gitignored — never commit real secrets.
# ─────────────────────────────────────────────────────────────

# Required — PostgreSQL connection string used by Prisma.
# Local Docker example: postgresql://darma:darma@localhost:5432/darma
DATABASE_URL=

# Required for admin auth — secret used to sign/verify the session JWT.
# Without it, /api/auth/login throws "Missing AUTH_SECRET".
# Generate one, e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# ── Admin seeding (optional) ───────────────────────────────────
# Used only by `npm run seed:admin` to upsert the admin user.
# Defaults shown; override the password before deploying.
ADMIN_EMAIL=admin@darma.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now

# ── Public / build-time (optional) ─────────────────────────────
# Google Analytics measurement id (analytics is skipped if unset).
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Absolute site URL used for SEO/canonical metadata, e.g. https://darma.dev
NEXT_PUBLIC_SITE_URL=
