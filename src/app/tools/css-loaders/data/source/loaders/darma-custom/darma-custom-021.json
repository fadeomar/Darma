    "color": true,
    "secondaryColor": true,
    "size": true,
    "speed": true,
    "background": false
  },
  "defaults": {
    "color": "#000000",
    "secondaryColor": "#dddddd",
    "size": 120,
    "speed": 1,
    "background": "#ffffff"
  },
