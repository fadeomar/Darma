  "css": ".container-espiral {\n  position: relative;\n  width: 160px;\n  height: 160px;\n  z-index: 50;\n  display: grid;\n  place-content: center;\n  overflow: hidden;\n}\n\n.loader {\nposition: absolute;\nleft: 50%;\ntop: 50%;\ntransform: rotate(calc(var(--r) * 45deg));\n}\n\n.circulo {\n--color: #0f0;\ntop: 0;\nwidth: 78px;\nheight: 2px;\nleft: -78px;\nposition: absolute;\ntransform-origin: right;\ntransform: rotate(calc(var(--i) * 18deg));\n}\n\n.circulo::before {\ncontent: \"\";\nposition: absolute;\ntop: -50%;\nwidth: 9px;\nheight: 9px;\nbackground-color: var(--color);\nborder-radius: 50%;\nbox-shadow:\n  0 0 8px var(--color),\n  0 0 16px var(--color),\n  0 0 28px var(--color),\n  0 0 44px var(--color);\nanimation: animate 5s linear infinite;\nanimation-delay: calc(var(--i) * -0.5s);\n}\n\n@keyframes animate {\n0% {\ntransform: translateX(78px) scale(1);\nopacity: 0;\n}\n10% {\nopacity: 1;\n}\n80% {\nopacity: 1;\n}\n100% {\ntransform: translateX(0px) scale(0);\nopacity: 1;\n}\n}",
